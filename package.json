{
  "name": "orca-notes",
  "version": "1.0.0",
  "description": "Private local desktop notes app with PIN lock",
  "main": "src/main.js",
  "scripts": {
    "build": "vite build",
    "start": "npm run build && electron .",
    "dev": "electron . --dev",
    "dev:ui": "vite",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder -mwl"
  },
  "keywords": [
    "electron",
    "notes",
    "markdown",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-character-count": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "lucide": "^0.577.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.orcanotes.app",
    "productName": "Orca Notes",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/main.js",
      "src/preload.js"
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  }
}
